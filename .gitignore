# 1. Folders generated by Projucer (Visual Studio, Xcode, etc.)
# IMPORTANT: Source code is in 'Source/', not in 'Builds/'
Builds/
JuceLibraryCode/

# 2. Hidden and temporary Visual Studio folders
.vs/
x64/
x86/
Debug/
Release/

# 3. User files and IDE caches
*.user
*.suo
*.sdf
*.db
*.opendb
*.VC.db
*.sln.docstates

# 4. Compiled binaries (The final plugin and compilation leftovers)
*.exe
*.dll
*.lib
*.obj
*.pdb
*.ilk
*.idb
*.exp
*.vst3
*.aaxplugin
*.component
*.app

# 5. Audio files (Avoid uploading giant 80MB audio files to the repository)
# If you want to keep test audio files, create a folder named 'TestAudio/' and do not ignore it.
*.wav
*.mp3
*.aif
*.aiff
*.flac

# 6. OS generated files (Especially if moving the project to Mac)
.DS_Store
Thumbs.db